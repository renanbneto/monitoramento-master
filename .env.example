APP_NAME=Monitoramento
APP_HTTP_PORTA=443
APP_ENV=local

# Somente desenvolvimento: pula login SIA/captcha (exige APP_ENV=local)
LOCAL_AUTH_BYPASS=false
#LOCAL_AUTH_EMAIL=dev@local.test
#LOCAL_AUTH_NAME=Desenvolvimento Local
#LOCAL_AUTH_AUTORIZACOES=Administrador;Auditoria
APP_KEY=  # Gere com: php artisan key:generate
APP_DEBUG=true
APP_URL=https://monitoramento.pm.pr.gov.br

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=monitoramento
DB_USERNAME=pmpr
DB_PASSWORD=pmpr

DB_AUDITORIA_CONNECTION=auditoria
DB_AUDITORIA_HOST=db
DB_AUDITORIA_PORT=5432
DB_AUDITORIA_DATABASE=auditoria
DB_AUDITORIA_USERNAME=pmpr
DB_AUDITORIA_PASSWORD=pmpr

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=7

MEMCACHED_HOST=memcached

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

#INTEGRAÇÃO SIA
DOMINIO_SIA=https://sia-auth.pm.pr.gov.br
PORTA_SIA=443
SIA_SSL_VERIFY=false
SIA_URL=https://sia-auth.pm.pr.gov.br
PATH_VIEW_LOGIN_SIA=api/view
PATH_RESET_SENHA_SIA=api/password
PATH_AUTH_SIA=api/auth
SIA_CHAVE_ASSINATURA="CHAVE_FORNECIDA_PELO_SIA"
SIA_ID_SOFTWARE=Monitoramento

#INTRANET
URL_INTRANET=https://intranet.pm.pr.gov.br

#CONFIGURAÇÃO
# Nota: o Laravel só lê o arquivo .env na raiz. Este .env.example é só modelo para o Git;
# copie para .env e ajuste. Valores abaixo são defaults seguros para documentação.

# Opcional: ao exibir câmeras (JSON / mapa), troca trecho do campo link (ex.: apontar streams para proxy local)
# CAMERAS_LINK_URL_SEARCH=https://monitoramento.pm.pr.gov.br
# CAMERAS_LINK_URL_REPLACE=http://127.0.0.1:8000

# URBS — webservice transporte coletivo (mapa /onibus). Em produção use o código oficial do portal (não commite credencial real neste arquivo se for público).
URBS_TRANSPORTE_BASE_URL=https://transporteservico.urbs.curitiba.pr.gov.br
URBS_TRANSPORTE_ACCESS_CODE=CODIGO_ACESSO_URBS
URBS_TRANSPORTE_ENDPOINT_LINHAS=getLinhas.php
URBS_TRANSPORTE_ENDPOINT_VEICULOS=getVeiculos.php
URBS_TRANSPORTE_CACHE_ONIBUS_TTL=120
URBS_TRANSPORTE_CACHE_LINHAS_TTL=3600
URBS_TRANSPORTE_HTTP_TIMEOUT=25
URBS_TRANSPORTE_HTTP_CONNECT_TIMEOUT=10
URBS_TRANSPORTE_USE_PROXY_IN_LOCAL=false
#URBS_TRANSPORTE_HTTP_PROXY=http://proxy-02.pr.gov.br:8000

#PATH_SISPICS_FOTOS=10.47.1.8/sispics/fotos/
